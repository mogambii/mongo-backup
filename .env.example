# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017

# Backup Settings
# DB_NAME: Leave empty to backup all databases, or specify a database name to backup only that database
# Examples:
#   (empty) - backs up all databases
#   admin - backs up only the admin database
#   myapp - backs up only the myapp database
DB_NAME=

BACKUP_DIR=./backups
MAX_BACKUPS=5

# Scheduler
# Cron expression for backup schedule (default: 2 AM daily)
# Format: second minute hour day month weekday
# 0 2 * * * = every day at 2:00 AM
BACKUP_SCHEDULE=0 2 * * *

# Authentication
# Password to login to the backup manager UI
# Change this to a strong password in production!
APP_PASSWORD=admin123

# Session secret for secure session management
# Change this to a random string in production!
SESSION_SECRET=your-secret-key-change-this-in-production

# Server
PORT=3000
NODE_ENV=development
